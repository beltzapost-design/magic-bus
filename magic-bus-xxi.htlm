<script>
function sendMail() {

}

// Animación ignición
function toggleSidebar() {
  var sidebar = document.querySelector('.sidebar');
  var overlay = document.getElementById('sidebar-overlay');
  sidebar.classList.toggle('open');
  overlay.classList.toggle('open');
}

window.addEventListener('load', function() {
  // Feedback formularios
  document.querySelectorAll('form').forEach(function(form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var data = new FormData(form);
      fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { 'Accept': 'application/json' }
      }).then(function(r) {
        if (r.ok) {
          form.reset();
          var ok = form.querySelector('.form-ok');
          if (ok) { ok.style.display = 'block'; setTimeout(function(){ ok.style.display='none'; }, 4000); }
        }
      });
    });
  });
  var digits = ['d9','d8','d7','d6','d5','d4','d3','d2','d1'];
  var i = 0;

  function reset() {
    digits.forEach(function(id) {
      var el = document.getElementById(id);
      el.classList.remove('activo','pasado');
    });
    var label = document.getElementById('ignicion-label');
    label.classList.remove('encendido');
    i = 0;
  }

  function next() {
    if (i > 0) {
      document.getElementById(digits[i-1]).classList.remove('activo');
      document.getElementById(digits[i-1]).classList.add('pasado');
    }
    if (i < digits.length) {
      document.getElementById(digits[i]).classList.add('activo');
      i++;
      setTimeout(next, 400);
    } else {
      var label = document.getElementById('ignicion-label');
      label.classList.add('encendido');
      // Pausa en IGNICIÓN y luego bucle
      setTimeout(function() {
        reset();
        setTimeout(next, 600);
      }, 1800);
    }
  }
  setTimeout(next, 800);
});
</script>

